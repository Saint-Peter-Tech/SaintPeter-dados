theme_minimal()
modulos <- c("bpm_status","pa_status","spo2_status","resp_status",
"temperatura_status","pic_status","pvc_status","ecg_status","etco2_status")
df_simulacao$hora <- as.integer(format(df_simulacao$timestamp, "%H"))
df_mod <- data.frame(
hora = df_simulacao$hora,
df_simulacao[modulos] =="Ativo"
)
df_mod <- aggregate(. ~ hora, data = df_mod, mean)
df_mod_qnt <- reshape(df_mod,varying = modulos,
v.names="valor",
timevar = "modulo",
times = modulos,
direction ="long")
ggplot(df_mod_qnt, aes(hora, valor, color = modulo)) +
geom_line() +
scale_x_continuous(breaks = 0:23) +
labs(title = "MÃ³dulos ativos por hora", x = "Hora", y = "Volume ativo") +
theme_minimal()
df_grupo <- rbind.data.frame(M6, M1)
library(ggplot2)
M6$maquina <- "M6"
M1$maquina <- "M1"
df_grupo <- rbind(M6, M1)
df_maquina <- aggregate(cbind(cpu_percent, ram_percent) ~ maquina,
data = df_grupo, mean)
print(df_maquina)
ggplot(df_grupo, aes(x = timestamp, y = cpu_percent, color = maquina)) +
geom_line() +
labs(title = "Uso de CPU por MÃ¡quina",
x = "Tempo", y = "CPU (%)") +
theme_minimal()
ggplot(df_grupo, aes(x = timestamp, y = ram_percent, color = maquina)) +
geom_line() +
labs(title = "Uso de RAM por MÃ¡quina",
x = "Tempo", y = "RAM (%)") +
theme_minimal()
ggplot(df_grupo, aes(x = timestamp, y = ram_percent, color = maquina)) +
geom_line() +
labs(title = "Uso de RAM por MÃ¡quina",
x = "Tempo", y = "RAM (%)") +
theme_minimal()
ggplot(df_grupo, aes(x = cpu_percent, y = ram_percent, color = maquina)) +
geom_point() +
labs(title = "CPU vs RAM por MÃ¡quina",
x = "CPU (%)", y = "RAM (%)") +
theme_minimal()
